---
import {
  API_ADMIN_TOKEN,
  API_BASE_URL,
  CF_ACCESS_DOMAIN,
  GITHUB_ORG_ID,
} from "astro:env/server";
import { Grid } from "../components/Grid";
import "../styles/global.css";

let users = null;

const auth = Astro.cookies.get("CF_Authorization");

let isAdmin = false;
let canManage = false;

const ADMIN_TEAMS = new Set(["Directors", "Production", "Managers"]);
const MANAGER_TEAMS = new Set([
  "Directors",
  "Production",
  "Team Leads",
  "Managers",
]);

let teams = new Set();

if (auth) {
  const identity = await fetch(
    `https://${CF_ACCESS_DOMAIN}/cdn-cgi/access/get-identity`,
    {
      headers: {
        Cookie: `CF_Authorization=${auth.value}`,
      },
    },
  ).then((data) => data.json());

  const myTeams = identity.teams;
  if (myTeams) {
    for (const team of myTeams) {
      if (team.org_id === GITHUB_ORG_ID) {
        teams.add(team.name);
        if (!isAdmin && ADMIN_TEAMS.has(team.name)) {
          isAdmin = true;
        }
        if (!canManage && MANAGER_TEAMS.has(team.name)) {
          canManage = true;
        }
      }
    }
  }
}

if (canManage && API_BASE_URL && API_ADMIN_TOKEN) {
  users = await fetch(`${API_BASE_URL}/api/admin/users`, {
    headers: {
      Authorization: `Bearer ${API_ADMIN_TOKEN}`,
    },
  })
    .then((res) => res.json())
    .then((data) => {
      if (data.success) {
        return data.result.members;
      } else {
        throw new Error("Member fetch failed!");
      }
    });

  if (!isAdmin) {
    users = users.filter((user: any) => {
      const userTeams = user.teams as string[];
      const userManager = userTeams.some((team) => MANAGER_TEAMS.has(team));
      // non-admins cannot manage other managers
      if (userManager) {
        return false;
      }
      // non-admins cannot manage other teams than their own
      return userTeams.some((team) => teams.has(team));
    });
  }
}
---

<style>
  html,
  body {
    height: 100%;
  }
</style>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{users ? "Project Borealis Admin" : "Access Denied."}</title>
  </head>
  <body class="dark:bg-gray-900">
    <div class="w-full h-full px-4 py-2">
      {
        users && (
          <>
            <div class="prose dark:prose-invert prose-h1:font-bold prose-h1:text-xl prose-a:text-blue-600 mb-2">
              <h1 class="mb-1">Project Borealis Admin</h1>
              <p class="mt-0">
                Welcome to the Project Borealis admin management panel.
              </p>
            </div>
            <Grid client:load initialRows={users} />
          </>
        )
      }
      {!users && <h1>Access Denied.</h1>}
    </div>
  </body>
</html>
