---
import { API_ADMIN_TOKEN, API_BASE_URL } from "astro:env/server";
import { Grid } from "@/components/Grid";
import { authorizeUser, canManageUser } from "@/utils/auth";
import "@/styles/global.css";

let users = null;

const auth = Astro.cookies.get("CF_Authorization");
const { isAdmin, canManage, teams } = await authorizeUser(auth?.value);

if (canManage && API_BASE_URL && API_ADMIN_TOKEN) {
  users = await fetch(`${API_BASE_URL}/api/admin/users`, {
    headers: {
      Authorization: `Bearer ${API_ADMIN_TOKEN}`,
    },
  })
    .then((res) => res.json())
    .then((data) => {
      if (data.success) {
        return data.result.members;
      } else {
        throw new Error("Member fetch failed!");
      }
    });

  if (!isAdmin) {
    users = users.filter((user: any) =>
      canManageUser(user.teams, { isAdmin, canManage, teams }),
    );
  }
}
---

<style>
  html,
  body {
    height: 100%;
  }
</style>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{users ? "Project Borealis Admin" : "Access Denied."}</title>
  </head>
  <body class="dark:bg-gray-900">
    <div class="w-full h-full px-4 py-2">
      <div
        class="prose dark:prose-invert prose-h1:font-bold prose-h1:text-xl prose-a:text-blue-600 mb-2"
      >
        {
          users && (
            <>
              <h1 class="mb-1">Project Borealis Admin</h1>
              <p class="mt-0">
                Welcome to the Project Borealis admin management panel.
              </p>
            </>
          )
        }
        {
          !users && (
            <h1 class="prose dark:prose-invert prose-h1:font-bold prose-h1:text-xl prose-a:text-blue-600 mb-2">
              Access Denied.
            </h1>
          )
        }
      </div>
      {
        users && (
          <>
            <Grid client:load initialRows={users} isAdmin={isAdmin} />
          </>
        )
      }
    </div>
  </body>
</html>
